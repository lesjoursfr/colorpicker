{
	"name": "@lesjoursfr/colorpicker",
	"version": "7.1.0",
	"description": "Colorpicker is a modular color picker plugin.",
	"license": "MIT",
	"repository": "lesjoursfr/colorpicker",
	"homepage": "https://github.com/lesjoursfr/colorpicker#readme",
	"bugs": {
		"url": "https://github.com/lesjoursfr/colorpicker/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": "22.x || 24.x || 26.x"
	},
	"browserslist": [
		"> 1%",
		"last 3 versions",
		"not dead"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"scripts": {
		"freshlock": "rm -rf node_modules/ && rm .yarn/install-state.gz && rm yarn.lock && yarn",
		"eslint-check": "eslint",
		"eslint-fix": "eslint --fix",
		"stylelint-check": "stylelint **/*.scss",
		"stylelint-fix": "stylelint **/*.scss --fix",
		"prettier-check": "prettier --check .",
		"prettier-fix": "prettier --write .",
		"test": "NODE_OPTIONS='--loader=ts-node/esm' mocha",
		"build-esm": "tsc && node assets.js",
		"build-browser": "webpack --mode production --config ./server/webpack.config.js --progress",
		"build": "npm run build-esm && npm run build-browser",
		"server": "webpack serve --mode development --config ./server/webpack.config.js --hot --open"
	},
	"keywords": [
		"colorpicker",
		"color",
		"picker"
	],
	"dependencies": {
		"@lesjoursfr/browser-tools": "^3.1.4"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@popperjs/core": "2.11.8",
		"@tsconfig/next": "2.0.6",
		"@types/jsdom": "28.0.3",
		"@types/mocha": "10.0.10",
		"@types/node": "24.13.0",
		"@types/webpack-env": "1.18.8",
		"color": "5.0.3",
		"css-loader": "7.1.4",
		"cssnano": "8.0.1",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"fs-extra": "11.3.5",
		"globals": "17.6.0",
		"jsdom": "29.1.1",
		"mini-css-extract-plugin": "2.10.2",
		"minimizer-webpack-plugin": "5.6.1",
		"mocha": "11.7.6",
		"postcss": "8.5.15",
		"prettier": "3.8.3",
		"sass": "1.100.0",
		"sass-loader": "17.0.0",
		"stylelint": "17.12.0",
		"stylelint-config-standard-scss": "17.0.0",
		"ts-loader": "9.6.0",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"webpack": "5.107.2",
		"webpack-cli": "7.0.3",
		"webpack-dev-server": "5.2.4"
	},
	"peerDependencies": {
		"@popperjs/core": "^2.11.8"
	},
	"dependenciesMeta": {
		"@parcel/watcher": {
			"built": true
		}
	},
	"packageManager": "yarn@4.16.0"
}
